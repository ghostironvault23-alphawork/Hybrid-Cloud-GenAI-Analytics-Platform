{
  "info": {
    "name": "Hybrid Cloud GenAI Analytics Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/health"
      }
    },
    {
      "name": "Ask AI",
      "request": {
        "method": "POST",
