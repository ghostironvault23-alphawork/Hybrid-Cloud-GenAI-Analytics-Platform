          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Why did payment service fail?\",\n  \"user_id\": \"demo-user\",\n  \"role\": \"Engineer\"\n}"
        },
        "url": "http://localhost:8000/ask-ai"
      }
    },
    {
      "name": "Summary Report",
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/reports/summary"
      }
    }
  ]
}
